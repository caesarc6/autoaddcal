{
  "name": "autaddcal",
  "version": "0.1.0",
  "description": "Sync Fast Retailing WPS work schedule to Google Calendar",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc && npm run build:client",
    "build:client": "npm run build -w client",
    "sync": "tsx src/cli/sync.ts",
    "sync:scheduled": "tsx scripts/thursday-sync.ts"
  },
  "workspaces": [
    "client"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "@supabase/supabase-js": "^2.49.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.50.1",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
