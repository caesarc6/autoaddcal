# Server
PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string

# Encryption key for stored tokens (32-byte hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron — set the same value in Vercel env; sent as Authorization: Bearer
CRON_SECRET=

# Google Calendar OAuth
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Thursday auto-sync: 4 checks until WPS posts the new week (comma-separated cron, Eastern)
# Used for local dev only — Vercel uses vercel.json crons (UTC, ~12/3/6/9 PM ET in standard time)
THURSDAY_SYNC_CRONS=0 12 * * 4,0 15 * * 4,0 18 * * 4,0 21 * * 4
SYNC_TIMEZONE=America/New_York
